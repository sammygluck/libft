	if (!s)
		return (NULL);
	/*if((size_t) start > ft_strlen(s))
		return(ft_strdup(""));*/
	sub = (char *)malloc((len + 1) * sizeof(char));
	if (!sub)
		return (NULL);
	i = 0;
	while (i < len && s[start + i])
	{
		sub[i] = s[start + i];
		i++;
	}
	sub[i] = '\0';
	return (sub);
}
