/*   Updated: 2023/01/17 18:17:52 by sgluck           ###   ########.fr       */
/*                                                                            */
/* ************************************************************************** */

#include "libft.h"

char	*ft_strrchr(char *str, int c)
{
	int	end;
	int	i;

	end = ft_strlen(str);
	while (0 <= end)
	{
		if (str[end] == (char) c)
			return ((char *)(str + end));
		end--;
	}
	return (NULL);
}

