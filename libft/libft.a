/* ************************************************************************** */
/*                                                                            */
/*                                                        :::      ::::::::   */
/*   ft_putnbr_fd.c                                     :+:      :+:    :+:   */
/*                                                    +:+ +:+         +:+     */
/*   By: sgluck <marvin@42.fr>                      +#+  +:+       +#+        */
/*                                                +#+#+#+#+#+   +#+           */
/*   Created: 2023/01/15 16:40:45 by sgluck            #+#    #+#             */
/*   Updated: 2023/01/22 17:12:48 by sgluck           ###   ########.fr       */
/*                                                                            */
/* ************************************************************************** */

#include "libft.h"

void	ft_putnbr_fd(int n, int fd)
{
	char	nbr;

	if (n == -2147483648)
	{
		write(fd, "-2", 2);
		n = 147483648;
	}
	if (n < 0)
	{
		write(fd, "-", 1);
		n = -n;
	}
	if (n > 9)
	{
		nbr = n % 10 + '0';
		ft_putnbr_fd(n / 10, fd);
	}
	if (n < 10)
	{
		nbr = n + '0';
		write(fd, &nbr, 1);
	}
}

int	main(void)
{
	ft_putnbr_fd(-2147483648, 1);
}

